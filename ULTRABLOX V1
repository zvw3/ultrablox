    // ========================================================================
    //  MASTER + OBSERVER
    // ========================================================================
    let raf = false;
    function applyAll() {
        if (raf) return; raf = true;
        requestAnimationFrame(() => {
            raf = false;
            doBrand(); doWM(); doBanner(); doPinned(); doPins();
            doAssetDownload(); doCopyId(); doRobuxConvert(); doLimitedChart();
            doRecentGames(); doProfileAge();
        });
    }
    const dApply = debounce(applyAll, 350);
    function setupObs() {
        new MutationObserver(ms => {
            for (const m of ms) for (const n of m.addedNodes)
                if (n.nodeType === 1 && !n.id?.startsWith('robloxplus') && !n.id?.startsWith('rp-') && !n.classList?.contains('rp-toast')) { dApply(); return; }
        }).observe(document.body, { childList: true, subtree: true });
    }

    // ========================================================================
    //  BOOT
    // ========================================================================
    function boot() {
        console.log('%c[Ultrablox]%c v5.0', 'color:#6366f1;font-weight:bold', 'color:#34d399');
        applyAll(); doSettings(); doSpotlight(); doCursorGlow(); doTimer(); doQuickRejoin(); setupObs();
        setTimeout(applyAll, 2500); setTimeout(doQuickRejoin, 3000);
    }
    if (document.body) boot(); else document.addEventListener('DOMContentLoaded', boot);
})();
