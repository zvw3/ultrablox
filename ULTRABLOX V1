    function applyChange() {
        injectCSS();
        ['robloxplus-welcome-banner', 'robloxplus-logo-badge', 'robloxplus-watermark', 'robloxplus-pinned-section', 'rp-timer', 'rp-glow', 'rp-dl-asset', 'rp-copy-id', 'rp-chart-panel', 'rp-recent', 'rp-rejoin', 'rp-age-badge'].forEach(id => {
            const e = document.getElementById(id); if (e) e.remove();
        });
        qA('.rp-pb').forEach(b => b.remove());
        qA('.rp-usd').forEach(b => b.remove());
        qA('[data-rp-usd]').forEach(el => delete el.dataset.rpUsd);
        applyAll(); doCursorGlow(); doTimer();
