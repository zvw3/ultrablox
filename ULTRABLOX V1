                    + '&search-page=games'; close();
            }
        });
        document.addEventListener('keydown', e => {
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                e.preventDefault();
                box.classList.contains('rp-on') ? close() : open();
            }
        });
    }

