    // ========================================================================
    function doPinned() {
        if (!S.pinnedGames) { const e = document.getElementById('robloxplus-pinned-section'); if (e) e.remove(); return; }
        const games = gP(); const ex = document.getElementById('robloxplus-pinned-section'); if (ex) ex.remove();
        if (!games.length) return;
        const sec = document.createElement('div'); sec.id = 'robloxplus-pinned-section';
        const hd = document.createElement('div'); hd.className = 'rp-ph';
