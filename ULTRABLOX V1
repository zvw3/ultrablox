    // ========================================================================
    //  FEATURE: ASSET DOWNLOAD BUTTON (shirts, pants, t-shirts, decals)
    // ========================================================================
    // Detects catalog item pages and injects a download button that fetches
    // the asset thumbnail at full resolution and triggers a file download.
    function doAssetDownload() {
        if (!S.assetDownload) return;
        // Only on catalog / library item pages
        const url = window.location.href;
        const catalogMatch = url.match(/\/(catalog|library)\/(\d+)/);
        if (!catalogMatch) return;
        const assetId = catalogMatch[2];

        // Don't double-inject
        if (document.getElementById('rp-dl-asset')) return;

        // Find the action buttons area (near Buy/Get/Price)
        const actionArea = document.querySelector(
            '.item-action-container, .action-button, [class*="action-button"], ' +
            '.PurchaseButton, [class*="purchase"], [class*="item-details"] .clearfix, ' +
            '#item-details-container .section-content, .item-details .price-container'
        );
        // Fallback: just find any container near the item header
        const target = actionArea || document.querySelector(
            '.item-details, #item-details-container, [class*="ItemDetails"]'
        );
        if (!target) return;

        const btn = document.createElement('button');
        btn.id = 'rp-dl-asset';
        btn.className = 'rp-dl-btn';
        btn.innerHTML = `${IC.download} Download Asset`;
        btn.title = 'Download this asset image (Roblox+ feature)';

        btn.addEventListener('click', () => {
            btn.innerHTML = `${IC.download} Downloading...`;
            btn.style.opacity = '0.6';
            btn.disabled = true;

            // Use Roblox thumbnails API for high-res image
            const thumbUrl = `https://thumbnails.roblox.com/v1/assets?assetIds=${assetId}&size=420x420&format=Png&isCircular=false`;

            GM_xmlhttpRequest({
                method: 'GET',
                url: thumbUrl,
                responseType: 'json',
                onload: function (res) {
                    try {
                        const data = typeof res.response === 'string' ? JSON.parse(res.response) : res.response;
                        if (data && data.data && data.data[0] && data.data[0].imageUrl) {
                            const imgUrl = data.data[0].imageUrl;
                            // Fetch the image as blob and download
                            GM_xmlhttpRequest({
                                method: 'GET',
                                url: imgUrl,
                                responseType: 'blob',
                                onload: function (imgRes) {
                                    const blobUrl = URL.createObjectURL(imgRes.response);
                                    const a = document.createElement('a');
                                    a.href = blobUrl;
                                    a.download = `roblox_asset_${assetId}.png`;
                                    document.body.appendChild(a);
                                    a.click();
                                    a.remove();
                                    URL.revokeObjectURL(blobUrl);
                                    btn.innerHTML = `${IC.download} Downloaded!`;
                                    btn.style.opacity = '1';
                                    setTimeout(() => { btn.innerHTML = `${IC.download} Download Asset`; btn.disabled = false; }, 2000);
                                    showToast('Asset downloaded!');
                                },
                                onerror: function () {
                                    // Fallback: open image in new tab
                                    window.open(imgUrl, '_blank');
                                    btn.innerHTML = `${IC.download} Download Asset`;
                                    btn.style.opacity = '1'; btn.disabled = false;
                                }
                            });
                        } else {
                            showToast('Could not fetch asset thumbnail');
                            btn.innerHTML = `${IC.download} Download Asset`;
                            btn.style.opacity = '1'; btn.disabled = false;
                        }
                    } catch (err) {
                        showToast('Download error — try again');
                        btn.innerHTML = `${IC.download} Download Asset`;
                        btn.style.opacity = '1'; btn.disabled = false;
                    }
                },
                onerror: function () {
                    showToast('Network error — try again');
                    btn.innerHTML = `${IC.download} Download Asset`;
                    btn.style.opacity = '1'; btn.disabled = false;
                }
            });
        });

        // Insert before the first child or append
        if (target.firstChild) target.insertBefore(btn, target.firstChild);
        else target.appendChild(btn);
    }

    // ========================================================================
    //  FEATURE: COPY ID BUTTON
    // ========================================================================
    // Shows a small "Copy ID" chip on catalog, game, and user profile pages.
    function doCopyId() {
        if (!S.copyId) return;
        if (document.getElementById('rp-copy-id')) return;

        const url = window.location.href;
        let id = null, label = '';

        // Detect page type and extract ID
        const catalogM = url.match(/\/(catalog|library)\/(\d+)/);
        const gameM = url.match(/\/(games|experiences)\/(\d+)/);
        const userM = url.match(/\/users\/(\d+)/);
        const groupM = url.match(/\/groups\/(\d+)/);

        if (catalogM) { id = catalogM[2]; label = 'Asset ID'; }
        else if (gameM) { id = gameM[2]; label = 'Place ID'; }
        else if (userM) { id = userM[2]; label = 'User ID'; }
        else if (groupM) { id = groupM[2]; label = 'Group ID'; }
        else return;

        // Find a header area to attach to
        const header = document.querySelector(
            '.item-name-container h1, .item-name-container h2, ' +
            '.game-name, [class*="game-title"], ' +
            '.header-title h1, .header-title h2, ' +
            '.profile-header .header-title, [class*="profile-header"] h1, ' +
            'h1, h2'
        );
        if (!header) return;

        const btn = document.createElement('button');
        btn.id = 'rp-copy-id';
        btn.className = 'rp-cid';
        btn.innerHTML = `${IC.copy} ${label}: ${id}`;
        btn.title = 'Click to copy';

        btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            navigator.clipboard.writeText(id).then(() => {
                btn.innerHTML = `${IC.copy} Copied!`;
                showToast(`${label} ${id} copied to clipboard`);
                setTimeout(() => { btn.innerHTML = `${IC.copy} ${label}: ${id}`; }, 1500);
            }).catch(() => {
                // Fallback for older browsers
                const ta = document.createElement('textarea');
                ta.value = id; document.body.appendChild(ta);
                ta.select(); document.execCommand('copy'); ta.remove();
                btn.innerHTML = `${IC.copy} Copied!`;
                showToast(`${label} ${id} copied`);
                setTimeout(() => { btn.innerHTML = `${IC.copy} ${label}: ${id}`; }, 1500);
            });
