        const pe = document.querySelector('#nav-profile .text-nav,#nav-profile .font-header-2,.age-bracket-label-username,[class*="authenticated-username"],.text-overflow.xsmall');
        if (pe && pe.textContent.trim()) u = pe.textContent.trim();
        if (!u) { const m = document.querySelector('meta[name="user-data"]'); if (m) try { const d = JSON.parse(m.getAttribute('content') || '{}'); u = d.displayName || d.name; } catch { } }
        if (!u) u = document.body.dataset?.displayName || document.body.dataset?.name || null;
        if (!u) for (const s of document.querySelectorAll('script')) { const m = s.textContent.match(/"displayName"\s*:\s*"([^"]+)"/); if (m) { u = m[1]; break; } }
        if (!u) u = 'Player';
        const h = new Date().getHours(); const g = h < 12 ? 'morning' : h < 18 ? 'afternoon' : 'evening';
        const el = document.createElement('div'); el.id = 'robloxplus-welcome-banner';
