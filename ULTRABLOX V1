    // ========================================================================
    function doSpotlight() {
        if (!S.spotlightSearch || document.getElementById('rp-spot-bg')) return;
        const bg = document.createElement('div'); bg.id = 'rp-spot-bg'; document.body.appendChild(bg);
        const box = document.createElement('div'); box.id = 'rp-spot-box';
        box.innerHTML = `<input type="text" placeholder="Search Roblox..." autocomplete="off" spellcheck="false"><div class="rp-spot-hint"><span>Press</span><span class="rp-spot-kbd">Esc</span><span>to close</span><span style="margin-left:auto">Ctrl+K to toggle</span></div>`;
        document.body.appendChild(box);
        const inp = box.querySelector('input');
        function open() { bg.classList.add('rp-on'); box.classList.add('rp-on'); inp.value = ''; setTimeout(() => inp.focus(), 50); }
        function close() { bg.classList.remove('rp-on'); box.classList.remove('rp-on'); }
        bg.addEventListener('click', close);
        inp.addEventListener('keydown', e => {
            if (e.key === 'Escape') close();
