    // ========================================================================
    //  FEATURE: ROBUX TO USD CONVERTER
    // ========================================================================
    // Finds Robux price elements and appends a small USD equivalent badge.
    // Rate: ~$0.0125 per Robux (purchase price) is the consumer-facing rate.
    const ROBUX_TO_USD = 0.0125;
    function doRobuxConvert() {
        if (!S.robuxConvert) return;

        // Find elements that display R$ amounts
        const priceEls = qA(
            '.text-robux-lg, .text-robux, .text-robux-tile, ' +
            '[class*="robux-price"], [class*="price-text"], ' +
            '.PriceLabel, .price-container .text-lead, ' +
            '.resale-price-container .text-lead'
        );

        priceEls.forEach(el => {
            // Skip if already annotated
            if (el.querySelector('.rp-usd') || el.dataset.rpUsd) return;
            el.dataset.rpUsd = 'true';

            // Extract numeric value: handle "123" or "1,234" or "Free"
            const rawText = el.textContent.replace(/,/g, '').trim();
            const num = parseInt(rawText.match(/\d+/)?.[0]);
            if (!num || isNaN(num)) return;

            const usd = (num * ROBUX_TO_USD).toFixed(2);
            const badge = document.createElement('span');
            badge.className = 'rp-usd';
            badge.innerHTML = `${IC.dollar} ~$${usd}`;
            badge.title = `Approx. USD value at R$${num}`;
            el.appendChild(badge);
        });
    }

    // ========================================================================
    //  FEATURE: LIMITED VALUE CHART (canvas-based resale price graph)
    // ========================================================================
    function doLimitedChart() {
        if (!S.limitedChart) return;
        const url = window.location.href;
        const m = url.match(/\/(catalog|library)\/(\d+)/);
        if (!m) return;
        const assetId = m[2];
        if (document.getElementById('rp-chart-panel')) return;

        // Check if this item has resale data (Limited items only)
        const apiUrl = `https://economy.roblox.com/v1/assets/${assetId}/resale-data`;
        GM_xmlhttpRequest({
            method: 'GET', url: apiUrl, responseType: 'json',
            onload: function (res) {
                try {
                    const data = typeof res.response === 'string' ? JSON.parse(res.response) : res.response;
                    if (!data || !data.priceDataPoints || data.priceDataPoints.length < 2) return;
                    renderChart(data, assetId);
                } catch { }
            }, onerror: function () { }
        });
    }

    function renderChart(data, assetId) {
        const points = data.priceDataPoints;
        const panel = document.createElement('div');
        panel.id = 'rp-chart-panel';

        // Header
        const head = document.createElement('div');
        head.className = 'rp-chart-head';
        head.innerHTML = `${IC.trending}<h3>Limited Value History</h3>`;
        panel.appendChild(head);

        // Chart wrapper
        const wrap = document.createElement('div');
        wrap.className = 'rp-chart-wrap';

        const canvas = document.createElement('canvas');
        canvas.width = 600; canvas.height = 180;
        wrap.appendChild(canvas);

        // Stats
        const prices = points.map(p => p.value);
        const latest = prices[prices.length - 1];
        const oldest = prices[0];
        const high = Math.max(...prices);
        const low = Math.min(...prices);
        const change = latest - oldest;
        const changePct = oldest > 0 ? ((change / oldest) * 100).toFixed(1) : 0;
        const isUp = change >= 0;

        const stats = document.createElement('div');
        stats.className = 'rp-chart-stats';
        stats.innerHTML = `
            <div class="rp-chart-stat"><span class="rp-chart-stat-label">Current RAP</span><span class="rp-chart-stat-val">R$ ${latest.toLocaleString()}</span></div>
            <div class="rp-chart-stat"><span class="rp-chart-stat-label">Highest</span><span class="rp-chart-stat-val">R$ ${high.toLocaleString()}</span></div>
            <div class="rp-chart-stat"><span class="rp-chart-stat-label">Lowest</span><span class="rp-chart-stat-val">R$ ${low.toLocaleString()}</span></div>
            <div class="rp-chart-stat"><span class="rp-chart-stat-label">Change</span>
                <span class="rp-chart-stat-val ${isUp ? 'rp-up' : 'rp-down'}">${isUp ? '+' : ''}${change.toLocaleString()}
                    <span class="rp-chart-badge ${isUp ? '' : 'rp-neg'}">${IC.trending} ${isUp ? '+' : ''}${changePct}%</span>
                </span>
            </div>`;
        wrap.appendChild(stats);
        panel.appendChild(wrap);

        // Insert into item details page
        const target = document.querySelector(
            '.item-details, #item-details-container, [class*="ItemDetails"], ' +
            '#container-main .content, .page-content'
        );
        if (target) {
            const existing = target.querySelector('.item-field-container, .action-button, [class*="action"]');
            if (existing) target.insertBefore(panel, existing.nextSibling);
            else target.appendChild(panel);
        }

        // Draw the chart on canvas
        requestAnimationFrame(() => drawChart(canvas, points));
    }

    function drawChart(canvas, points) {
        const ctx = canvas.getContext('2d');
        const W = canvas.width, H = canvas.height;
        const pad = { t: 10, r: 10, b: 25, l: 50 };
        const cW = W - pad.l - pad.r, cH = H - pad.t - pad.b;

        const prices = points.map(p => p.value);
        const minP = Math.min(...prices) * 0.95;
        const maxP = Math.max(...prices) * 1.05;
        const range = maxP - minP || 1;

        ctx.clearRect(0, 0, W, H);

        // Grid lines
        ctx.strokeStyle = 'rgba(150,150,200,0.08)';
        ctx.lineWidth = 1;
        for (let i = 0; i <= 4; i++) {
            const y = pad.t + (cH / 4) * i;
            ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(W - pad.r, y); ctx.stroke();
            // Y-axis labels
            const val = maxP - (range / 4) * i;
            ctx.fillStyle = 'rgba(150,150,200,0.4)';
            ctx.font = '10px Inter, sans-serif';
            ctx.textAlign = 'right';
            ctx.fillText(Math.round(val).toLocaleString(), pad.l - 6, y + 3);
        }

        // Build path points
        const pts = prices.map((v, i) => ({
            x: pad.l + (i / (prices.length - 1)) * cW,
            y: pad.t + cH - ((v - minP) / range) * cH
        }));

        // Gradient fill under curve
        const style = getComputedStyle(document.documentElement);
        const acColor = style.getPropertyValue('--ac').trim() || '#6366f1';
        const grad = ctx.createLinearGradient(0, pad.t, 0, H - pad.b);
        grad.addColorStop(0, acColor + '30');
        grad.addColorStop(1, acColor + '00');
        ctx.beginPath();
        ctx.moveTo(pts[0].x, H - pad.b);
        pts.forEach(p => ctx.lineTo(p.x, p.y));
        ctx.lineTo(pts[pts.length - 1].x, H - pad.b);
        ctx.closePath();
        ctx.fillStyle = grad;
        ctx.fill();

        // Line
        ctx.beginPath();
        ctx.moveTo(pts[0].x, pts[0].y);
        for (let i = 1; i < pts.length; i++) {
            const cp1x = (pts[i - 1].x + pts[i].x) / 2;
            ctx.bezierCurveTo(cp1x, pts[i - 1].y, cp1x, pts[i].y, pts[i].x, pts[i].y);
        }
        ctx.strokeStyle = acColor;
        ctx.lineWidth = 2.5;
        ctx.stroke();

        // Endpoint dot
        const last = pts[pts.length - 1];
        ctx.beginPath();
        ctx.arc(last.x, last.y, 4, 0, Math.PI * 2);
        ctx.fillStyle = acColor;
        ctx.fill();
        ctx.beginPath();
        ctx.arc(last.x, last.y, 6, 0, Math.PI * 2);
        ctx.strokeStyle = acColor + '40';
        ctx.lineWidth = 2;
        ctx.stroke();
    }

    // ========================================================================
    //  FEATURE: RECENTLY PLAYED (auto-tracks game page visits)
    // ========================================================================
    function getRecent() { try { return JSON.parse(GM_getValue('rp_recent', '[]')); } catch { return []; } }
    function saveRecent(list) { GM_setValue('rp_recent', JSON.stringify(list)); }

    // Track current page if it's a game
    function trackGameVisit() {
        const url = window.location.href;
        const m = url.match(/\/(games|experiences)\/(\d+)/);
        if (!m) return;
        const gameId = m[2];
        const name = document.querySelector('.game-name, [class*="game-title"], h1')?.textContent?.trim() || 'Game';
        const thumb = document.querySelector('meta[property="og:image"]')?.content || '';

        let recent = getRecent();
        recent = recent.filter(g => g.id !== gameId);
        recent.unshift({ id: gameId, n: name, t: thumb, u: url, ts: Date.now() });
        if (recent.length > 12) recent = recent.slice(0, 12);
        saveRecent(recent);
    }
    trackGameVisit();

    function doRecentGames() {
        if (!S.recentGames) { const e = document.getElementById('rp-recent'); if (e) e.remove(); return; }
        const recent = getRecent();
        if (!recent.length) return;
        if (document.getElementById('rp-recent')) return;
        // Only show on homepage
        if (!window.location.pathname.match(/^\/(home)?$/)) return;

        const sec = document.createElement('div'); sec.id = 'rp-recent';
        const hd = document.createElement('div'); hd.className = 'rp-rh';
        hd.innerHTML = `${IC.history}<span>recently played</span>`;
        sec.appendChild(hd);

        const row = document.createElement('div'); row.className = 'rp-rg';
        recent.slice(0, 8).forEach(g => {
            const c = document.createElement('div'); c.className = 'rp-rc';
            c.innerHTML = `<img src="${g.t || ''}" alt="${g.n}" loading="lazy" onerror="this.style.background='var(--rpH)';this.src=''"><div class="rp-rn">${g.n}</div>`;
            c.addEventListener('click', () => { window.location.href = g.u; });
            row.appendChild(c);
        });
        sec.appendChild(row);

        // Insert after pinned section or welcome banner
        const after = document.getElementById('robloxplus-pinned-section') || document.getElementById('robloxplus-welcome-banner');
        if (after && after.parentNode) after.parentNode.insertBefore(sec, after.nextSibling);
        else {
            const mc = document.querySelector('#container-main,.content,[class*="HomePageContainer"]');
            if (mc) mc.prepend(sec);
        }
    }

