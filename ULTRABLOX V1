    // ========================================================================
    //  FEATURE: PROFILE AGE BADGE
    // ========================================================================
    function doProfileAge() {
        if (!S.profileAge) return;
        if (document.getElementById('rp-age-badge')) return;
        const url = window.location.href;
        const m = url.match(/\/users\/(\d+)/);
        if (!m) return;

        // Look for the join date element on the profile
        const dateEl = document.querySelector('.profile-stats-container .text-lead, .profile-about .text-default, [class*="join-date"], .tooltip-pastnames');
        // Try to find join date from page content
        const allText = document.body.innerText;
        const joinMatch = allText.match(/Join Date[:\s]*([A-Z][a-z]+ \d{1,2}, \d{4})/i)
            || allText.match(/(\d{1,2}\/\d{1,2}\/\d{4})/);

        let ageText = '';
        if (joinMatch) {
            const joinDate = new Date(joinMatch[1]);
            if (!isNaN(joinDate)) {
                const diff = Date.now() - joinDate.getTime();
                const days = Math.floor(diff / 86400000);
                const years = Math.floor(days / 365);
                const months = Math.floor((days % 365) / 30);
                if (years > 0) ageText = `${years}y ${months}m old`;
                else if (months > 0) ageText = `${months}m ${days % 30}d old`;
                else ageText = `${days}d old`;
            }
        }
        if (!ageText) return;

        const header = document.querySelector('.profile-header .header-title, [class*="profile-header"] h1, .profile-display-name, h1');
        if (!header) return;

        const badge = document.createElement('span'); badge.id = 'rp-age-badge'; badge.className = 'rp-age';
        badge.innerHTML = `${IC.calendar} ${ageText}`;
        badge.title = joinMatch ? `Joined: ${joinMatch[1]}` : 'Account age';
        header.parentNode.insertBefore(badge, header.nextSibling);
    }

