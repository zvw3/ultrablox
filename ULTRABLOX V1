    // ========================================================================
    //  UTILITIES
    // ========================================================================
    function debounce(fn, ms) { let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); }; }
    function qA(s) { try { return [...document.querySelectorAll(s)]; } catch { return []; } }
    function showToast(m) {
        const o = document.getElementById('rp-toast'); if (o) o.remove();
        const t = document.createElement('div'); t.id = 'rp-toast'; t.className = 'rp-toast';
        t.innerHTML = `<span style="display:flex">${IC.pin}</span><span>${m}</span>`;
        document.body.appendChild(t); requestAnimationFrame(() => t.classList.add('rp-show'));
        setTimeout(() => { t.classList.remove('rp-show'); setTimeout(() => t.remove(), 300); }, 2000);
    }
    function gid(u) { if (!u) return null; const m = u.match(/\/(games|experiences)\/(\d+)/i); return m ? m[2] : null; }

    // ========================================================================
    //  PINNED GAMES
    // ========================================================================
    function gP() { try { return JSON.parse(GM_getValue('rp_pins', '[]')); } catch { return []; } }
    function sP(g) { GM_setValue('rp_pins', JSON.stringify(g)); }
    function addPin(d) { const g = gP(); if (g.some(x => gid(x.u) === gid(d.u))) return false; g.unshift(d); sP(g); return true; }
    function rmPin(u) { const id = gid(u); let g = gP(); const l = g.length; g = g.filter(x => gid(x.u) !== id); sP(g); return g.length < l; }
    function isPin(u) { const id = gid(u); return id && gP().some(x => gid(x.u) === id); }

