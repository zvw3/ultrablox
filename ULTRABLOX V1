    // ========================================================================
    //  FEATURE: PIN BUTTONS
    // ========================================================================
    function doPins() {
        if (!S.pinnedGames) return;
        qA('.game-card,.game-card-container,[class*="game-card-link"],li[class*="game-card"],div[class*="game-tile"],a[href*="/games/"]').forEach(card => {
            if (card.querySelector('.rp-pb')) return;
            if (getComputedStyle(card).position === 'static') card.style.position = 'relative';
            let lk = card.querySelector('a[href*="/games/"],a[href*="/experiences/"]');
            if (!lk && card.tagName === 'A' && (card.href || '').match(/\/(games|experiences)\//)) lk = card;
            if (!lk) lk = card.closest('a[href*="/games/"],a[href*="/experiences/"]');
            const url = lk ? lk.href : ''; const id = gid(url); if (!id) return;
            const img = card.querySelector('img'); const ne = card.querySelector('.game-card-name,[class*="game-card-name"],[class*="game-name"],[title]');
            const tu = img ? (img.src || img.dataset?.src || '') : ''; const nm = ne ? (ne.textContent.trim() || ne.getAttribute('title') || '') : '';
            const b = document.createElement('button'); b.className = 'rp-pb'; b.title = 'Pin'; b.innerHTML = IC.pin;
            if (isPin(url)) { b.classList.add('rp-pd'); b.innerHTML = IC.pinFill; b.title = 'Unpin'; }
            b.addEventListener('click', e => {
                e.preventDefault(); e.stopPropagation(); e.stopImmediatePropagation();
                if (isPin(url)) { rmPin(url); b.classList.remove('rp-pd'); b.innerHTML = IC.pin; showToast('Unpinned "' + nm + '"'); }
                else { if (addPin({ u: url, t: tu, n: nm || 'Game ' + id })) { b.classList.add('rp-pd'); b.innerHTML = IC.pinFill; showToast('Pinned "' + nm + '"'); } }
                doPinned();
            }, true);
            card.appendChild(b);
        });
    }
    function refreshPins() {
        qA('.rp-pb').forEach(b => {
            const c = b.parentElement;
            let l = c.querySelector('a[href*="/games/"],a[href*="/experiences/"]');
            if (!l && c.tagName === 'A') l = c; if (!l) l = c.closest('a[href*="/games/"]');
            const u = l ? l.href : ''; if (u && isPin(u)) { b.classList.add('rp-pd'); b.innerHTML = IC.pinFill; }
            else { b.classList.remove('rp-pd'); b.innerHTML = IC.pin; }
        });
    }

